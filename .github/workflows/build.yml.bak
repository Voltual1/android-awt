name: Android Build & Release

on:
  push:
    branches:
      - master
  workflow_dispatch: # 支持手动触发

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      # 步骤 1：先使用 JDK 17 满足最新 sdkmanager 的运行要求
      - name: Set up JDK 17 for SDK Manager
        uses: actions/setup-java@v4
        with:
          distribution: 'temurin'
          java-version: '17'

      # 步骤 2：安装项目指定的 Android NDK 版本
      - name: Install Android NDK
        run: |
          echo "y" | $ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager --install "ndk;22.0.7026061"

      # 步骤 3：切换回 JDK 11 以确保与旧版本 Gradle 兼容
      - name: Set up JDK 11 for Gradle Build
        uses: actions/setup-java@v4
        with:
          distribution: 'temurin'
          java-version: '11'

      # 步骤 4：直接在 runner 上安装特定版本的 Gradle (如 6.7.1)
      - name: Setup Gradle
        uses: gradle/actions/setup-gradle@v3
        with:
          gradle-version: 7.3.3

      # 自动从 awtcompat/build.gradle 提取版本号
      - name: Set Version Output
        id: version
        run: |
          VERSION=$(grep -oP "version\s+'\K[^']+" awtcompat/build.gradle || echo "1.0.4")
          echo "BUILD_VERSION=${VERSION}-${{ github.run_number }}" >> $GITHUB_OUTPUT

      # 编译并发布到本地 Maven 仓库
      - name: Build & Publish to Maven Local
        run: |
          gradle publishToMavenLocal
        env:
          MAVEN_PUBLISH_USERNAME: "mock_user"
          MAVEN_PUBLISH_PASSWORD: "mock_password"

      # 提取包含所有 ABI 的单体 AAR 文件并重命名为统一的发布包
      - name: Prepare Release Artifacts
        run: |
          mkdir -p output
          AAR_FILE=$(find ~/.m2/repository/ro/andob/androidawt/androidawt -name "*.aar" | head -n 1)
          if [ -f "$AAR_FILE" ]; then
            cp "$AAR_FILE" output/MC2MT-android.aar
            echo "Successfully copied $AAR_FILE to output/MC2MT-android.aar"
          else
            echo "Error: Generated AAR file not found in local Maven repository!"
            exit 1
          fi

      # 创建草稿发行版并上传包含了所有 ABI 的 AAR 归档包
      - name: Create Draft Release
        if: (github.event_name == 'push' && github.ref == 'refs/heads/master') || github.event_name == 'workflow_dispatch'
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ steps.version.outputs.BUILD_VERSION }}
          name: "Android Build ${{ steps.version.outputs.BUILD_VERSION }}"
          draft: true
          body: |
            ### Automated Build Artifacts
            This release contains the compiled AAR library supporting all major Android ABIs (armeabi-v7a, arm64-v8a, x86, x86_64).
          files: |
            output/android-awt.aar
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}